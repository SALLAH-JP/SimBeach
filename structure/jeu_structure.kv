<JeuScreen>:
    name: "jeu"

    BoxLayout:
        orientation: "vertical"

        BoxLayout:
            size_hint_y: 0.1125
            padding: dp(5)
            spacing: dp(10)

            canvas.before:
                Color:
                    rgba: 0.2, 0.2, 0.2, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]

            ButtonIcon:
                icon_source: "assets/icones/icone_home.png"
                text: ""
                size_hint: (0.3, 0.8)
                pos_hint: {"center_y": 0.5}
                icon_pos: self.center_x - dp(16), self.center_y - dp(16)
                on_release: app.root.current = "accueil"

            Label:
                id: score
                text: "Score: 0"
                font_size: '20sp'
            Label:
                id: best_score
                text: f"Meilleur Score: {app.config['best_score']}"
                font_size: '20sp'

            ButtonIcon:
                id: bouton
                icon_source: "assets/icones/icone_start.png"
                text: ""
                size_hint: (0.3, 0.8)
                pos_hint: {"center_y": 0.5}
                icon_pos: self.center_x - dp(16), self.center_y - dp(16)
                on_release: root.jeu_widget.load_level()


        FloatLayout:
            Video:
                id: background
                source: "assets/backgrounds/plage3.mp4"
                state: "play"
                options: {'eos': 'loop'}
                allow_stretch: True
                keep_ratio: False
                size : self.size
                pos_hint: {"center_x": 0.5, "center_y": 0.5}


            DimmingWidget:
                id: jeu_widget
                Label:
                    id: game_over
                    text:""
                    font_size:"50sp"
                    size:(300, 100)
                    pos:self.parent.center_x - 125, self.parent.center_y